      "source": [
        "import ultralytics\n",
        "ultralytics.checks()\n",
        "\n",
        "from ultralytics import YOLO\n",
        "\n",
        "# Load the model (this succeeds in Colab)\n",
        "model = YOLO(\"fire.pt\")\n",
        "\n",
        "# Export and Slim in one step\n",
        "model.export(format=\"onnx\", imgsz=640, simplify=True, name=\"slimmed_fire.onnx\")"
      ]
